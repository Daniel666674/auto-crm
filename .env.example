##############################################################################
# BlackScale Nexus CRM — Environment Variables
# Copy to .env.local (dev) or .env.production (VPS) and fill in all values.
# Never commit the filled-in file to git.
#
# Authentication: Google Workspace SSO — no passwords stored here.
# Only @blackscale.consulting Google accounts can log in.
##############################################################################

# ─── APP ────────────────────────────────────────────────────────────────────

# Public URL of the app (no trailing slash)
NEXT_PUBLIC_APP_URL=https://crm.blackscale.consulting

# Node environment: development | production
NODE_ENV=production

# ─── AUTH ───────────────────────────────────────────────────────────────────

# NextAuth secret — signs and verifies JWT sessions
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here-at-least-32-chars

# Full canonical URL of the app (must match your domain exactly)
NEXTAUTH_URL=https://crm.blackscale.consulting

# ─── GOOGLE (REQUIRED — Login + optional Calendar + GA4) ────────────────────

# OAuth 2.0 credentials — used for login AND Google Calendar
# Create at: https://console.cloud.google.com/apis/credentials
# Add authorized redirect URIs:
#   https://crm.blackscale.consulting/api/auth/callback/google
#   https://crm.blackscale.consulting/api/auth/callback/google-calendar
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Google Analytics 4 property ID (format: 123456789)
# Get from: Google Analytics → Admin → Property Settings
GA4_PROPERTY_ID=your-ga4-property-id

# Service account credentials JSON, base64-encoded (for GA4 server-side access)
# Create a service account in GCP, grant it Analytics Reader role, download JSON key
# Encode with: base64 -w0 service-account.json
GA4_CREDENTIALS=base64-encoded-service-account-json

# OAuth redirect URI for Google Calendar specifically
GOOGLE_CALENDAR_REDIRECT_URI=https://crm.blackscale.consulting/api/auth/callback/google-calendar

# ─── DATABASE ───────────────────────────────────────────────────────────────

# 32-byte hex key for SQLCipher at-rest database encryption
# Generate with: openssl rand -hex 32
# REQUIRED in production — app exits if missing.
# SQLCipher must be compiled into better-sqlite3 on the VPS.
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# ─── BREVO ──────────────────────────────────────────────────────────────────

# Brevo (formerly Sendinblue) API key
# Get from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...

# Integration mode: "webhook" (real-time) or "polling" (every 30 min, default)
BREVO_WEBHOOK_MODE=polling

# Webhook secret for validating Brevo webhook signatures (webhook mode only)
# Set in Brevo dashboard → Transactional → Webhooks
BREVO_WEBHOOK_SECRET=your-brevo-webhook-secret

# ─── ANTHROPIC ──────────────────────────────────────────────────────────────

# Optional: Claude API for inline AI lead classification in the web UI
# Without this, classification uses rule-based scoring (100% local, works great)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── VAPID (Web Push Notifications) ─────────────────────────────────────────

# Generate VAPID keys with: npx web-push generate-vapid-keys
# The public key must have the NEXT_PUBLIC_ prefix to reach the browser
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Email shown in push subscription (mailto: format required)
VAPID_EMAIL=mailto:daniel.acosta@blackscale.consulting

# ─── RESEND (Optional email digest) ─────────────────────────────────────────

# Resend API key for sending daily digest emails
# Get from: https://resend.com/ (free tier available)
RESEND_API_KEY=re_...

# Recipient email for the digest
DIGEST_EMAIL=daniel.acosta@blackscale.consulting

# Sender address (must be a verified domain in Resend)
DIGEST_FROM=BlackScale Nexus <nexus@blackscale.consulting>
